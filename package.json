{
  "name": "slack-thread-intercom-bridge",
  "version": "0.1.0",
  "description": "An open-source Intercom-to-Slack bridge that posts new Intercom chats into Slack threads and lets your team reply in the same thread to send messages back to customers in Intercom.",
  "scripts": {
    "test": "vitest run",
    "build": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": false,
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@slack/web-api": "^7.14.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "inngest": "^3.52.4",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@vercel/node": "^5.6.9",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
